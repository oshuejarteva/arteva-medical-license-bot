# ============================================================================
#  Medical License Bot — Шаблон переменных окружения
# ============================================================================
#
#  Как использовать:
#    1. Скопируйте этот файл:  cp .env.example .env
#    2. Заполните все обязательные (*) переменные
#    3. Запустите:              docker compose up -d
#
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
#  OpenRouter — LLM и Embeddings API (обязательные)
# ─────────────────────────────────────────────────────────────────────────────
#  Получить ключ: https://openrouter.ai/keys
#  * API-ключ для доступа к моделям (обязательно)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

#  Модель генерации ответов (по умолчанию: google/gemini-2.0-flash-001)
#  Список доступных: https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-2.0-flash-001

#  Модель для генерации эмбеддингов (по умолчанию: openai/text-embedding-3-small)
#  Размерность 1536 — совместима с настройкой QDRANT_DIMENSION
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# ─────────────────────────────────────────────────────────────────────────────
#  Telegram Bot (обязательные)
# ─────────────────────────────────────────────────────────────────────────────
#  Получить токен: https://t.me/BotFather → /newbot
#  * Токен бота (обязательно)
TELEGRAM_TOKEN=123456789:ABCDefGhIjKlMnOpQrStUvWxYz

#  Имя бота (должно совпадать с тем, что задано в BotFather)
TELEGRAM_USERNAME=MedLicenseBot

#  Список chat ID администраторов через запятую
#  Только эти пользователи смогут выполнять /reindex в Telegram
#  Узнать свой chat ID: https://t.me/userinfobot
TELEGRAM_ADMIN_CHAT_IDS=123456789,987654321

# ─────────────────────────────────────────────────────────────────────────────
#  REST API — аутентификация (обязательные)
# ─────────────────────────────────────────────────────────────────────────────
#  Логин и пароль для Basic Auth на защищённых эндпоинтах (/reindex)
#  * Пароль администратора (обязательно, сменить на надёжный!)
API_ADMIN_USERNAME=admin
API_ADMIN_PASSWORD=change-me-strong-password

# ─────────────────────────────────────────────────────────────────────────────
#  Rate Limiting — ограничение количества запросов
# ─────────────────────────────────────────────────────────────────────────────
#  Максимум HTTP-запросов с одного IP в минуту (по умолчанию: 30)
RATE_LIMIT_RPM=30

# ─────────────────────────────────────────────────────────────────────────────
#  Qdrant — векторная база данных
# ─────────────────────────────────────────────────────────────────────────────
#  При запуске через docker-compose эти значения устанавливаются автоматически.
#  Раскомментируйте только при локальной разработке без Docker.
# QDRANT_HOST=localhost
# QDRANT_PORT=6334
# QDRANT_COLLECTION=medical-documents
# QDRANT_DIMENSION=1536
